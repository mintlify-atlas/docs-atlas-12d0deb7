  "keyFeatures": [
    "Role-based access control with 6 roles: PAYPAC, ORGANIZER, STAFF, STAFF_PROMOTER, PROMOTER, CUSTOMER",
    "Full event lifecycle management from creation to finalization",
    "Ticket issuance, transfer, validation, and TOTP-based QR code support",
    "Invoice and payment processing via Wompi payment gateway",
    "Promoter system with reward rules and balance tracking",
    "Real-time WebSocket notifications and ticket status updates",
    "Background jobs for email queues, event finalization, and ticket transfer expiry",
    "Numbered venue seating with zones, rows, and seat-level status management",
    "Firebase Authentication integration with JWT",
    "Email notifications via Brevo and SMS via Onurix"
  ],
  "publicApiSurface": [
    "POST /api/auth/register",
